{
  "name": "meta-ads-agents",
  "version": "0.0.0",
  "private": true,
  "description": "Agência de tráfego Meta Ads 100% operada por IAs (SPEC-000). Monorepo modular.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "web",
    "packages/*",
    "landing-pages/_template",
    "worker/*"
  ],
  "scripts": {
    "lint": "eslint . && npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "build:libs": "npm run build -w @template/lp-render",
    "typecheck": "npm run build:libs && tsc --noEmit && npm run typecheck --workspaces --if-present",
    "test": "npm run build:libs && vitest run && npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vitest": "^2.1.5"
  }
}
