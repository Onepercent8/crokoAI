{
  "name": "@template/lp-render",
  "version": "0.0.0",
  "private": true,
  "description": "Fonte única dos tipos ContentDoc/Theme/Settings, catálogo das 17 seções da landing page, serializer e libs de domínio de apresentação (checkout/affiliate/utm/consent). Domínio puro, sem I/O (SPEC-000 §8, ADR 0013/0017).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/base.css": "./src/react/base.css",
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "import": "./dist/skills/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/react/base.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
