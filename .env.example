# =============================================================================
# SPEC-000 — Contrato de variáveis de ambiente (fonte canônica)
# =============================================================================
# Este arquivo É a lista canônica de variáveis (SPEC-000 §2/§7). Mantenha-o
# sempre completo. Copie para `.env.local` e preencha os valores (dev).
# Em produção: runner recebe via `fly secrets`; dashboard via env do Vercel.
#
# REGRAS:
#  - Segredos NUNCA no código nem em arquivos versionados (só aqui, vazios).
#  - `NEXT_PUBLIC_*` são expostas ao browser — NUNCA coloque segredo nelas.
#  - `.env.local` é gitignored; este `.env.example` é versionado (SEM VALORES).
# =============================================================================

# === Anthropic (Claude) — LLM de decisão + Claude Code CLI ====================
# Obter em: https://platform.claude.com/  (runner também usa OAuth do CLI)
CLAUDE_API_KEY=
# Modelos do Nexus (configuráveis; default no código: claude-sonnet-4-6)
NEXUS_MODEL=
NEXUS_REVIEW_MODEL=

# === OpenAI — geração de imagem (gpt-image) + STT (Whisper) ===================
# Obter em: https://platform.openai.com/
OPENAI_API_KEY=

# === Supabase — Postgres + Storage + Auth =====================================
# Obter em: Supabase Dashboard > Project Settings > API / Database
SUPABASE_URL=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Postgres via pooler transaction-mode (IPv4). Formato:
# DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres?pgbouncer=true"
DATABASE_URL=
# Postgres via pooler session-mode (migrations). Formato:
# DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"
DIRECT_URL=

# === Upstash Redis — cache + rate limit + idempotência ========================
# Obter em: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Upstash QStash — scheduler dinâmico (OPCIONAL) ===========================
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# === Cloudflare — Pages (landing pages) + Worker (tracking) + DNS =============
# Obter em: https://dash.cloudflare.com/  (API Tokens / Turnstile)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# === ElevenLabs — TTS (voz do Nexus) ==========================================
# Obter em: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# === Picovoice — wake word ("Nexus") ==========================================
# Obter em: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=      # exposta ao browser (wake word client-side)

# === Resend — email do modo autônomo (OPCIONAL) ===============================
# Obter em: https://resend.com/
RESEND_API_KEY=
AUTONOMOUS_NOTIFY_EMAIL=               # destino das notificações do modo autônomo
AUTONOMOUS_FROM_EMAIL=                 # remetente verificado no Resend

# === Telegram — notificação das análises (OPCIONAL) ===========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Dashboard (Vercel) — autenticação ========================================
# DASHBOARD_PASSWORD: hash SHA-256 da senha (NÃO a senha em texto puro).
#   Gerar: printf '%s' 'sua-senha' | shasum -a 256 | awk '{print $1}'
DASHBOARD_PASSWORD=
# AUTH_SECRET: ≥32 bytes aleatórios (assina o cookie JWT de sessão).
#   Gerar: openssl rand -base64 48
AUTH_SECRET=

# === Meta Marketing API =======================================================
# NÃO há token Meta em env. A autenticação é feita na vinculação do MCP
# `mcp-meta-ads` no Claude Code. As skills falam com a Meta SOMENTE via o MCP.
