{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run typecheck)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run format)",
      "Bash(npm run format:fix)",
      "Bash(npm run build)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(.env.production)",
      "Read(.env.development)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(supabase db reset:*)",
      "Bash(npx supabase db reset:*)",
      "Bash(supabase db push:*)",
      "Bash(npx supabase db push:*)",
      "Bash(fly secrets:*)",
      "Bash(flyctl secrets:*)",
      "Bash(fly deploy:*)",
      "Bash(vercel:*)"
    ]
  },
   "env": {
    "CLAUDE_CODE_EXPERIMENTAL_TEAMS_AGENT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; [ -n \"$f\" ] && npx prettier --write \"$f\" --ignore-unknown; } 2>/dev/null || true",
            "statusMessage": "Formatando com Prettier..."
          }
        ]
      }
    ]
  }
}
